{
  "expo": {
    "name": "TradeFlow",
    "slug": "tradeflow-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#111827"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#111827"
      },
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.tradeflow1.tradeflow",
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow TradeFlow to attach before and after job photos.",
          "cameraPermission": "Allow TradeFlow to take before and after job photos."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#111827",
          "defaultChannel": "default"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "ee4aebca-6b1e-478e-9b57-3716caa034a1"
      }
    },
    "owner": "tradeflow1"
  }
}
