{
  "expo": {
    "name": "TradeFlow",
    "slug": "tradeflow-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#111827"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#111827"
      },
      "softwareKeyboardLayoutMode": "resize"
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow TradeFlow to attach before and after job photos.",
          "cameraPermission": "Allow TradeFlow to take before and after job photos."
        }
      ]
    ]
  }
}
